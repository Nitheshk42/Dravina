generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  balance   Float    @default(0)
  createdAt DateTime @default(now())

  transactions Transaction[]
  deposits Deposit[]
  recipients Recipient[]
}

model Transaction {
  id             String   @id @default(uuid())
  userId         String
  amountSent     Float
  amountReceived Float
  currency       String
  country        String
  exchangeRate   Float
  fee            Float
  status         String   @default("Completed")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Deposit {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  status    String   @default("Completed")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Recipient {
  id            String   @id @default(uuid())
  userId        String
  fullName      String
  email         String
  phone         String
  country       String
  bankAccount   String
  ifscCode      String
  transferringTo String  @default("Someone Else")
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

